        </mxCell>
        <mxCell id="tp1" value="HAA&lt;br&gt;Proj" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="225" width="70" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="tp2" value="HFE&lt;br&gt;Proj" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="225" width="70" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="tp3" value="KFE&lt;br&gt;Proj" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="225" width="70" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="tp4" value="Generic&lt;br&gt;Proj" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="225" width="70" height="35" as="geometry"/>
        </mxCell>

        <!-- Projected Output -->
        <mxCell id="proj_out" value="&lt;b&gt;Projected Features&lt;/b&gt;&lt;br&gt;[N × 48]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="310" width="220" height="50" as="geometry"/>
        </mxCell>

        <!-- Conv1 -->
        <mxCell id="conv1" value="&lt;b&gt;GATv2Conv Layer 1&lt;/b&gt;&lt;br&gt;(48→48, heads=2, concat=True)&lt;br&gt;→ LayerNorm(96) + ELU&lt;br&gt;&lt;i&gt;Output: [N × 96]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="400" width="340" height="80" as="geometry"/>
        </mxCell>

        <!-- Conv2 -->
        <mxCell id="conv2" value="&lt;b&gt;GATv2Conv Layer 2&lt;/b&gt;&lt;br&gt;(96→48, heads=1, concat=False)&lt;br&gt;→ LayerNorm(48) + ELU&lt;br&gt;&lt;i&gt;Output: [N × 48]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="520" width="340" height="80" as="geometry"/>
        </mxCell>

        <!-- Node Embeddings -->
        <mxCell id="ne" value="&lt;b&gt;Node Embeddings [N × 48]&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="640" width="260" height="40" as="geometry"/>
        </mxCell>

        <!-- Actor Head -->
        <mxCell id="actor" value="&lt;b&gt;ACTOR HEAD&lt;/b&gt;&lt;br&gt;(Per joint node)&lt;br&gt;Linear(48→32) + Tanh&lt;br&gt;Linear(32→1)&lt;br&gt;→ μ[12] + log_σ[12]&lt;br&gt;&lt;b&gt;Output: Normal(μ, σ)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="720" width="220" height="120" as="geometry"/>
        </mxCell>

        <!-- Critic Head -->
        <mxCell id="critic" value="&lt;b&gt;CRITIC HEAD&lt;/b&gt;&lt;br&gt;(Global mean pool)&lt;br&gt;Linear(48→32) + Tanh&lt;br&gt;Linear(32→1)&lt;br&gt;&lt;b&gt;Output: V(s) ∈ ℝ&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="720" width="220" height="120" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="a31" edge="1" source="inp" target="tp_box3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a32" edge="1" source="tp_box3" target="proj_out" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a33" edge="1" source="proj_out" target="conv1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a34" edge="1" source="conv1" target="conv2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a35" edge="1" source="conv2" target="ne" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a36" value="joint nodes only" edge="1" source="ne" target="actor" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a37" value="all nodes (pooled)" edge="1" source="ne" target="critic" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Param count -->
        <mxCell id="pc" value="&lt;b&gt;Total Parameters: 29,566&lt;/b&gt;" style="text;html=1;align=center;fontSize=14;fontColor=#FF0000;" vertex="1" parent="1">
          <mxGeometry x="400" y="860" width="300" height="30" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ================================================================== -->
  <!-- PAGE 4: Figure 4 - GATv2Conv Message Passing                       -->
  <!-- ================================================================== -->
  <diagram id="fig4" name="Fig 4 - GATv2 Message Passing">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t4" value="&lt;b&gt;Figure 4: GATv2Conv Message-Passing Mechanism&lt;/b&gt;" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- Central Node -->
        <mxCell id="center" value="&lt;b&gt;LF_HFE&lt;/b&gt;&lt;br&gt;(Target Node i)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="300" width="130" height="80" as="geometry"/>
        </mxCell>

        <!-- Neighbor 1 -->
        <mxCell id="n1" value="&lt;b&gt;LF_HAA&lt;/b&gt;&lt;br&gt;(Neighbor j₁)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="150" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- Neighbor 2 -->
        <mxCell id="n2" value="&lt;b&gt;LF_KFE&lt;/b&gt;&lt;br&gt;(Neighbor j₂)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="150" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- Edges with attention -->
        <mxCell id="e41" value="α₁ = 0.62" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=3;strokeColor=#b85450;" edge="1" source="n1" target="center" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e42" value="α₂ = 0.38" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="n2" target="center" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Attention formula -->
        <mxCell id="attn_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="440" width="1000" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="attn_title" value="&lt;b&gt;GATv2 Dynamic Attention (Brody et al., ICLR 2022)&lt;/b&gt;" style="text;html=1;align=center;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="350" y="450" width="420" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="f1" value="&lt;b&gt;1. Concatenate &amp; Transform:&lt;/b&gt;&lt;br&gt;e_ij = LeakyReLU(W · [h_i || h_j || edge_attr_ij])" style="text;html=1;align=left;fontSize=12;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="485" width="450" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="f2" value="&lt;b&gt;2. Compute Attention:&lt;/b&gt;&lt;br&gt;α_ij = softmax_j(a^T · e_ij)    ← Dynamic: depends on BOTH i and j" style="text;html=1;align=left;fontSize=12;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="535" width="500" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="f3" value="&lt;b&gt;3. Aggregate:&lt;/b&gt;&lt;br&gt;h_i' = Σ_j α_ij · W_val · h_j    (multi-head: concat or average)" style="text;html=1;align=left;fontSize=12;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="585" width="500" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="f4" value="&lt;b&gt;Key Difference from GAT:&lt;/b&gt;&lt;br&gt;GAT: a^T · [W·h_i || W·h_j] — static attention (ranking of neighbors is independent of query)&lt;br&gt;GATv2: a^T · LeakyReLU(W · [h_i || h_j]) — dynamic attention (ranking depends on query node)" style="text;html=1;align=left;fontSize=11;spacingLeft=10;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="485" width="460" height="80" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>


  <!-- ================================================================== -->
  <!-- PAGE 6: Figure 9 - Morphology Transfer                             -->
  <!-- ================================================================== -->
  <diagram id="fig9" name="Fig 9 - Morphology Transfer">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t9" value="&lt;b&gt;Figure 9: Morphology Transfer — Quadruped to Hexapod&lt;/b&gt;" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="550" height="40" as="geometry"/>
        </mxCell>

        <!-- Quadruped Side -->
        <mxCell id="q_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="560" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="q_label" value="&lt;b&gt;Quadruped (ANYmal — 12 joints)&lt;/b&gt;" style="text;html=1;align=center;fontSize=14;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="140" y="85" width="350" height="30" as="geometry"/>
        </mxCell>

        <!-- Quadruped Graph -->
        <mxCell id="qb" value="BODY" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="270" y="140" width="80" height="45" as="geometry"/>
        </mxCell>
        <!-- 4 legs -->
        <mxCell id="q_l1" value="LF" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="90" y="220" width="50" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="q_l2" value="LH" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="180" y="220" width="50" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="q_l3" value="RF" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="380" y="220" width="50" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="q_l4" value="RH" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="470" y="220" width="50" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="qe1" edge="1" source="qb" target="q_l1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="qe2" edge="1" source="qb" target="q_l2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="qe3" edge="1" source="qb" target="q_l3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="qe4" edge="1" source="qb" target="q_l4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Each leg has 3 joints -->
        <mxCell id="q1a" value="HAA" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="280" width="40" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="q1b" value="HFE" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="280" width="40" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="q1c" value="KFE" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="95" y="320" width="40" height="25" as="geometry"/>
        </mxCell>

        <!-- Properties -->
        <mxCell id="q_props" value="&lt;b&gt;Properties:&lt;/b&gt;&lt;br&gt;• 13 nodes (1 body + 12 joints)&lt;br&gt;• 24 edges (bidirectional)&lt;br&gt;• 4 legs × 3 joints (HAA,HFE,KFE)&lt;br&gt;• Action dim: 12&lt;br&gt;• Node dim: 26&lt;br&gt;• Params: 29,566" style="text;html=1;align=left;fontSize=11;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="260" height="140" as="geometry"/>
        </mxCell>

        <!-- The shared GNN in middle -->
        <mxCell id="shared_gnn" value="&lt;b&gt;SAME GNN Weights&lt;/b&gt;&lt;br&gt;&lt;br&gt;Type projections are&lt;br&gt;role-indexed, not&lt;br&gt;position-indexed.&lt;br&gt;&lt;br&gt;GATv2Conv operates on&lt;br&gt;arbitrary graph topology.&lt;br&gt;&lt;br&gt;&lt;b&gt;→ Zero-shot transfer!&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="380" width="200" height="200" as="geometry"/>
        </mxCell>

        <!-- Hexapod Side -->
        <mxCell id="h_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;" vertex="1" parent="1">

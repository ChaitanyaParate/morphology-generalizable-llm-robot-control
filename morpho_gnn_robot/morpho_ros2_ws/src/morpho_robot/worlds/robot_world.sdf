<sdf version="1.9">
  <world name="default">

    <gravity>0 0 -9.81</gravity>

    <!-- Ground plane (manual, no model:// dependency) -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>

        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </visual>

      </link>
    </model>

    <!-- Light -->
    <light name="sun" type="directional">
      <direction>-0.5 0.5 -1</direction>
    </light>

    

  </world>
</sdf>